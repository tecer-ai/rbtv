{
  "$schema": "design-tokens-schema",
  "metadata": {
    "title": "Design Tokens: {website-name}",
    "source": "{url}",
    "date": "{current-date}"
  },
  "colors": {
    "primary": "#000000",
    "secondary": "#000000",
    "neutral": {
      "100": "#F5F5F5",
      "200": "#E5E5E5",
      "300": "#D4D4D4",
      "400": "#A3A3A3",
      "500": "#737373",
      "600": "#525252",
      "700": "#404040",
      "800": "#262626",
      "900": "#171717"
    },
    "accent": "#000000",
    "background": {
      "primary": "#FFFFFF",
      "secondary": "#F5F5F5"
    }
  },
  "typography": {
    "fontFamily": {
      "primary": "Font Name",
      "secondary": "Font Name",
      "monospace": "Font Name"
    },
    "fontSize": {
      "h1": "48px",
      "h2": "36px",
      "h3": "24px",
      "h4": "20px",
      "h5": "18px",
      "h6": "16px",
      "body": "16px",
      "small": "14px",
      "caption": "12px"
    },
    "fontWeight": {
      "regular": "400",
      "medium": "500",
      "semibold": "600",
      "bold": "700"
    },
    "lineHeight": {
      "tight": "1.2",
      "normal": "1.5",
      "relaxed": "1.75"
    }
  },
  "spacing": {
    "base": "8px",
    "xs": "8px",
    "sm": "16px",
    "md": "24px",
    "lg": "32px",
    "xl": "48px",
    "2xl": "64px"
  },
  "layout": {
    "maxWidth": "1200px",
    "columns": 12,
    "gap": "16px",
    "containerPadding": "24px"
  },
  "visual": {
    "borderRadius": {
      "none": "0px",
      "sm": "4px",
      "md": "8px",
      "lg": "16px",
      "full": "9999px"
    },
    "shadow": {
      "sm": "0px 1px 2px rgba(0,0,0,0.05)",
      "md": "0px 2px 8px rgba(0,0,0,0.08)",
      "lg": "0px 4px 16px rgba(0,0,0,0.12)"
    }
  }
}
