{
  "$schema": "design-tokens-schema",
  "metadata": {
    "title": "Design Tokens: {website-name}",
    "source": "{url}",
    "date": "{current-date}",
    "pagesAnalyzed": [],
    "extractionMethod": "dom+screenshot"
  },
  "colors": {
    "primary": "#000000",
    "secondary": "#000000",
    "neutral": {
      "100": "#F5F5F5",
      "200": "#E5E5E5",
      "300": "#D4D4D4",
      "400": "#A3A3A3",
      "500": "#737373",
      "600": "#525252",
      "700": "#404040",
      "800": "#262626",
      "900": "#171717"
    },
    "accent": "#000000",
    "background": {
      "primary": "#FFFFFF",
      "secondary": "#F5F5F5"
    }
  },
  "typography": {
    "fontFamily": {
      "primary": "Font Name",
      "secondary": "Font Name",
      "monospace": "Font Name"
    },
    "fontFace": [
      {
        "family": "Font Name",
        "src": "url()",
        "weight": "400",
        "style": "normal",
        "display": "swap"
      }
    ],
    "fontSize": {
      "h1": "48px",
      "h2": "36px",
      "h3": "24px",
      "h4": "20px",
      "h5": "18px",
      "h6": "16px",
      "body": "16px",
      "small": "14px",
      "caption": "12px"
    },
    "fontWeight": {
      "regular": "400",
      "medium": "500",
      "semibold": "600",
      "bold": "700"
    },
    "lineHeight": {
      "tight": "1.2",
      "normal": "1.5",
      "relaxed": "1.75"
    },
    "letterSpacing": {
      "tight": "-0.02em",
      "normal": "0",
      "wide": "0.05em",
      "wider": "0.1em"
    }
  },
  "spacing": {
    "base": "8px",
    "xs": "8px",
    "sm": "16px",
    "md": "24px",
    "lg": "32px",
    "xl": "48px",
    "2xl": "64px"
  },
  "layout": {
    "maxWidth": "1200px",
    "columns": 12,
    "gap": "16px",
    "containerPadding": "24px",
    "breakpoints": {
      "sm": "640px",
      "md": "768px",
      "lg": "1024px",
      "xl": "1280px",
      "2xl": "1536px"
    }
  },
  "visual": {
    "borderRadius": {
      "none": "0px",
      "sm": "4px",
      "md": "8px",
      "lg": "16px",
      "full": "9999px"
    },
    "shadow": {
      "sm": "0px 1px 2px rgba(0,0,0,0.05)",
      "md": "0px 2px 8px rgba(0,0,0,0.08)",
      "lg": "0px 4px 16px rgba(0,0,0,0.12)"
    },
    "opacity": {
      "muted": "0.6",
      "disabled": "0.4",
      "overlay": "0.5"
    },
    "zIndex": {
      "base": "0",
      "dropdown": "10",
      "sticky": "20",
      "modal": "50",
      "tooltip": "100"
    }
  },
  "transition": {
    "duration": {
      "fast": "150ms",
      "normal": "300ms",
      "slow": "500ms"
    },
    "easing": {
      "default": "ease",
      "in": "ease-in",
      "out": "ease-out",
      "inOut": "ease-in-out"
    },
    "animation": {}
  },
  "cssVariables": {},
  "alphaScale": {
    "white": {
      "10": "rgba(255,255,255,0.1)",
      "20": "rgba(255,255,255,0.2)",
      "50": "rgba(255,255,255,0.5)"
    },
    "black": {
      "10": "rgba(0,0,0,0.1)",
      "20": "rgba(0,0,0,0.2)",
      "50": "rgba(0,0,0,0.5)"
    },
    "brand": {}
  }
}
