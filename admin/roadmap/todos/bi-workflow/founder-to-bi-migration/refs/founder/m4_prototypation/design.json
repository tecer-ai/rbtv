{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://robotville.local/standards/design_rules.json",
  "title": "Robotville Design Rules Contract",
  "description": "Schema + machine-readable contract for Robotville design tokens and deliverables layout specs. This file contains no concrete design values (no colors, no font families). Read design_brief.md for narrative design direction. Project-specific design-[artifact_type].json files contain concrete values.",

  "anyOf": [
    { "$ref": "#/$defs/layoutSpec" },
    { "$ref": "#/$defs/tokenContract" }
  ],

  "$defs": {
    "tokenName": {
      "type": "string",
      "pattern": "^--[a-z0-9-]+$",
      "$comment": "CSS custom property name. Example format: --bg"
    },

    "tokenList": {
      "type": "array",
      "items": { "$ref": "#/$defs/tokenName" },
      "minItems": 1,
      "uniqueItems": true
    },

    "tokenContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract", "coreTokens", "artifactExtensions"],
      "properties": {
        "contract": {
          "const": "robotville_design_token_contract_v1"
        },
        "coreTokens": {
          "$ref": "#/$defs/tokenList"
        },
        "artifactExtensions": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/tokenList" },
          "properties": {
            "landing_page": { "$ref": "#/$defs/tokenList" },
            "presentation": {
              "type": "array",
              "items": { "$ref": "#/$defs/tokenName" },
              "uniqueItems": true
            },
            "infographic": { "$ref": "#/$defs/tokenList" }
          }
        }
      }
    },

    "layout": {
      "type": "string",
      "enum": ["1_column", "2_columns", "3_columns", "grid"]
    },

    "content": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "description": { "type": "string" },
        "button": { "type": "string" },
        "image": { "type": "string" },
        "icon": { "type": "string" }
      }
    },

    "column": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content"],
      "properties": {
        "content": { "$ref": "#/$defs/content" }
      }
    },

    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "layout", "background_color", "columns"],
      "properties": {
        "name": { "type": "string" },
        "layout": { "$ref": "#/$defs/layout" },
        "background_color": {
          "type": "string",
          "$comment": "May be a color string or a gradient string; schema does not enforce concrete values."
        },
        "columns": {
          "type": "array",
          "items": { "$ref": "#/$defs/column" },
          "minItems": 1
        }
      }
    },

    "layoutSpec": {
      "type": "object",
      "additionalProperties": true,
      "required": ["artifact_type", "sections"],
      "properties": {
        "$schema": { "type": "string" },
        "$extends": {
          "type": "string",
          "$comment": "Legacy support only. Prefer $schema."
        },
        "artifact_type": { "type": "string" },
        "sections": {
          "type": "array",
          "items": { "$ref": "#/$defs/section" },
          "minItems": 1
        }
      }
    }
  },

  "x_tokenContract": {
    "contract": "robotville_design_token_contract_v1",
    "coreTokens": [
      "--bg",
      "--surface",
      "--text",
      "--muted",
      "--border",
      "--accent",
      "--danger",
      "--success",
      "--font-sans",
      "--font-display",
      "--font-mono",
      "--space-1",
      "--space-2",
      "--space-3",
      "--space-4",
      "--space-6",
      "--space-8",
      "--radius-1",
      "--radius-2",
      "--shadow-1"
    ],
    "artifactExtensions": {
      "landing_page": ["--gradient-hero", "--gradient-primary"],
      "presentation": [],
      "infographic": ["--accent-2", "--accent-3"]
    }
  }
}
